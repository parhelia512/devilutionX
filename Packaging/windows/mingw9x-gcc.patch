 #define __gthread_mutex_unlock __gthr_win32_mutex_unlock
 #define __gthread_recursive_mutex_trylock __gthr_win32_recursive_mutex_trylock
 
+/* Windows 9x compatibility: TryEnterCriticalSection and GetThreadId do not
+   exist there.  Resolve them dynamically so that they do not end up in the
+   static import table (the Windows 9x loader rejects binaries importing
+   them) and degrade gracefully when they are unavailable.  */
+#define WIN32_LEAN_AND_MEAN
+#include <windows.h>
+
+static inline FARPROC
+__gthr_win32_get_kernel32_proc (const char *__name)
+{
+  return GetProcAddress (GetModuleHandleA ("KERNEL32.DLL"), __name);
+}
+
+static inline BOOL WINAPI
+__gthr_win32_TryEnterCriticalSection (LPCRITICAL_SECTION __cs)
+{
+  typedef BOOL (WINAPI *__fn_t) (LPCRITICAL_SECTION);
+  static __fn_t __fn = (__fn_t) -1;
+  if (__fn == (__fn_t) -1)
+    __fn = (__fn_t) __gthr_win32_get_kernel32_proc ("TryEnterCriticalSection");
+  return __fn != 0 ? __fn (__cs) : FALSE;
+}
+
+#define TryEnterCriticalSection __gthr_win32_TryEnterCriticalSection
+
+static inline DWORD WINAPI
+__gthr_win32_GetThreadId (HANDLE __thr)
+{
+  typedef DWORD (WINAPI *__fn_t) (HANDLE);
+  static __fn_t __fn = (__fn_t) -1;
+  if (__fn == (__fn_t) -1)
+    __fn = (__fn_t) __gthr_win32_get_kernel32_proc ("GetThreadId");
+  return __fn != 0 ? __fn (__thr) : 0;
+}
+
+#define GetThreadId __gthr_win32_GetThreadId
+
